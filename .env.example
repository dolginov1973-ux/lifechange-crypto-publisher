# Copy to .env for LOCAL testing only. NEVER commit .env.
# In CI these come from GitHub Actions Secrets (secrets.TELEGRAM_BOT_TOKEN, etc).

# Required: Telegram bot token for @LifeChange_ResearchBot (bot is admin in both channels).
TELEGRAM_BOT_TOKEN=

# Optional: public link to the community group. If empty, CTA "community" lines are dropped
# (the literal "[community link]" is NEVER published).
COMMUNITY_LINK=

# Optional: force a specific "now" for local testing, ISO-8601 UTC, e.g. 2026-06-25T12:30:00Z
# Leave empty in production.
NOW_OVERRIDE=
